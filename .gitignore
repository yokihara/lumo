# SwiftPM 빌드 산출물
.build/
.swiftpm/

# 배포 산출물 (make-app.sh / release.sh가 생성)
dist/

# macOS
.DS_Store

# Xcode (CLI 빌드만 쓰지만 혹시 모를 경우 대비)
*.xcuserstate

# 아이콘 빌드 중간 산출물 (scripts/make-icon.swift가 생성)
AppIcon.iconset/

# 참고: AppIcon.icns 는 scripts/make-icon.swift 로 생성되는 파일이지만
# make-app.sh 가 번들에 그대로 복사하므로 빌드에 필요하다.
# 따라서 git 에서 무시하지 않고 커밋해 둔다.
# (재생성이 필요하면: swift scripts/make-icon.swift)

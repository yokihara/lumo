# SwiftPM build artifacts
.build/
.swiftpm/

# Distribution artifacts (produced by make-app.sh / release.sh)
dist/

# macOS
.DS_Store

# Xcode (we build via CLI, but just in case)
*.xcuserstate

# Icon build intermediates (produced by scripts/make-icon.swift)
AppIcon.iconset/

# Note: AppIcon.icns is generated by scripts/make-icon.swift, but make-app.sh copies it
# into the bundle, so it's needed for the build — keep it committed rather than ignored.
# (Regenerate with: swift scripts/make-icon.swift)
